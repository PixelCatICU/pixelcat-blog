<% if (page.total && page.total > 1) { %>
  <nav class="pagination" aria-label="分页">
    <% if (page.prev_link) { %>
      <a class="pagination-link" href="<%- url_for(page.prev_link) %>" rel="prev">上一页</a>
    <% } else { %>
      <span class="pagination-link disabled">上一页</span>
    <% } %>
    <span class="pagination-status"><%= page.current %> / <%= page.total %></span>
    <% if (page.next_link) { %>
      <a class="pagination-link" href="<%- url_for(page.next_link) %>" rel="next">下一页</a>
    <% } else { %>
      <span class="pagination-link disabled">下一页</span>
    <% } %>
  </nav>
<% } %>
